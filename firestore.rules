rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isMember(coupleId) {
      return isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /couples/{coupleId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.createdBy;
      allow update: if isAuth() && (
        request.auth.uid in resource.data.members ||
        (resource.data.partnerJoined == false &&
         resource.data.members.size() == 1 &&
         request.auth.uid in request.resource.data.members)
      );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId) && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }

      match /loveNotes/{noteId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId) && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }

      match /memories/{memoryId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /events/{eventId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /expenses/{expenseId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /wishlist/{itemId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /dateFund/{doc} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /musicRoom/{doc} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /musicQueue/{songId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /musicHistory/{songId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if false;
        allow delete: if false;
      }

      match /callState/{doc} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /callSignals/{doc} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /gameState/{doc} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /videoCall/{doc} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /videoSignals/{doc} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      match /videoChat/{messageId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

    }
  }
}